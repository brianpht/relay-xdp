[Unit]
Description=relay-xdp - UDP game relay with XDP packet processing
Documentation=https://github.com/{{ github_repo }}
After=network.target relay-module.service
Wants=relay-module.service

[Service]
Type=simple
# relay-xdp requires root / CAP_BPF to attach XDP programs and load eBPF maps.
User=root
Group=root
EnvironmentFile={{ relay_conf_dir }}/relay.env
ExecStart={{ relay_data_dir }}/relay-xdp
Restart=on-failure
RestartSec=10s
TimeoutStartSec=60s
TimeoutStopSec=30s

# Grant only the capabilities required for XDP and BPF map management.
# CAP_NET_ADMIN  - attach XDP to interface, set socket options
# CAP_BPF        - load/pin BPF programs and maps (kernel 5.8+)
# CAP_SYS_ADMIN  - required by some aya operations on older kernels
AmbientCapabilities=CAP_NET_ADMIN CAP_BPF CAP_SYS_ADMIN
CapabilityBoundingSet=CAP_NET_ADMIN CAP_BPF CAP_SYS_ADMIN

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=relay-xdp

[Install]
WantedBy=multi-user.target

