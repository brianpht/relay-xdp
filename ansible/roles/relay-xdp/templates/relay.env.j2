# relay-xdp environment - managed by Ansible, do not edit manually.
RUST_LOG={{ rust_log }}
RUST_BACKTRACE={{ rust_backtrace }}
RELAY_NAME={{ relay_name }}
RELAY_UDP_PORT={{ relay_udp_port }}
RELAY_HTTP_PORT={{ relay_http_port }}
# ansible_host is the EIP - stable public address used for inter-relay comms.
RELAY_PUBLIC_ADDRESS={{ ansible_host }}:{{ relay_udp_port }}
# ansible_default_ipv4.address is the VPC private IP - used for XDP NIC bind.
RELAY_INTERNAL_ADDRESS={{ ansible_default_ipv4.address }}:{{ relay_udp_port }}
RELAY_BACKEND_URL=http://{{ hostvars[groups['backend_servers'][0]]['ansible_host'] }}:{{ backend_http_port }}
RELAY_DEDICATED={{ relay_dedicated }}
RELAY_PUBLIC_KEY={{ vault_relay_keys[relay_name].public_key }}
RELAY_PRIVATE_KEY={{ vault_relay_keys[relay_name].private_key }}
RELAY_BACKEND_PUBLIC_KEY={{ vault_relay_backend_public_key }}
RELAY_XDP_OBJ={{ relay_data_dir }}/relay_xdp_rust.o
RELAY_PING_INTERVAL_MS={{ relay_ping_interval_ms }}
RELAY_UPDATE_INTERVAL_MS={{ relay_update_interval_ms }}
RELAY_SESSION_TIMEOUT_S={{ relay_session_timeout_s }}

