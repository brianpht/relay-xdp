# Redis configuration managed by Ansible - do not edit manually.
# Environment: {{ ansible_environment | default('unknown') }}

bind 127.0.0.1
port {{ redis_port }}
daemonize no
supervised systemd
loglevel notice
logfile /var/log/redis/redis-server.log

# Working directory - AOF and RDB files are stored here
dir /var/lib/redis

# Persistence - AOF only, RDB disabled for relay workload
save ""
appendonly yes
appendfilename "appendonly.aof"
appendfsync everysec
no-appendfsync-on-rewrite no

# Memory limit
maxmemory {{ redis_maxmemory }}
maxmemory-policy allkeys-lru

# Security - no password required (loopback only)
# protected-mode yes enforced by bind 127.0.0.1
protected-mode yes

# Performance
tcp-backlog 511
tcp-keepalive 300
hz 15

